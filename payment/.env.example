APP_PORT=8005
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
CORS_ORIGIN=*

# Debe ser EXACTAMENTE el mismo valor que JWT_SECRET en api/ -- los tokens
# los emite api al hacer login, este servicio solo los valida.

# Opcional: si no se define, se usa amqp://guest:guest@localhost:5672/
# Se publican eventos subscription.* (activated/renewed/failed/canceled/
# expiring) para que api/ los consuma y genere notificaciones -- ese
# consumidor todavía no existe (ver spec sección 2). Si RabbitMQ no está
# disponible, el servicio sigue funcionando normal, solo no se publican.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Sin cuenta de Stripe todavía: deja estas 5 vacías. El servicio arranca
# igual (health, /subscriptions/plans y /ads/* funcionan), pero crear o
# cancelar una suscripción responde 503 hasta que se configuren.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASICO=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
