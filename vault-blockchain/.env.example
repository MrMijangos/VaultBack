# Vara Network
VARA_NODE_URL=wss://testnet.vara.network
VARA_CONTRACT_ID=0x...         # Program ID del contrato desplegado en testnet (ver contracts/asset_certificate)
VARA_MNEMONIC=word1 word2 ...  # frase semilla de la wallet del servicio (nunca la subas a git)
VARA_NETWORK=testnet           # testnet | mainnet
VARA_GAS_LIMIT=                # opcional: gasLimit fijo en unidades de gas. Si se deja vacío, se estima con calculateGas.handle

# Postgres (mismo proyecto Supabase que usan api/ y payment/, pero via
# conexion directa con "pg" -- igual que api/ y payment/ usan DB_HOST/DB_USER/etc,
# aqui se usa DATABASE_URL porque es el connection string que da el pooler de Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require

# RabbitMQ -- mismo exchange topic "vault.events" que usan api/ y payment/ (ver
# api/src/core/eventbus/Publisher.go y payment/src/core/eventbus/Publisher.go)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# App
PORT=3001
