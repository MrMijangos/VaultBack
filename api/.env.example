APP_NAME=Vault
APP_VERSION=0.0.1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=vault
DB_PASSWORD=changeme
DB_USER=vault_user
DB_SSL=false

APP_PORT=8080
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
CORS_ORIGIN=*
COOKIE_SECURE=false

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opcional: si no se define, se usa amqp://guest:guest@localhost:5672/
# Usado solo para asset.updated (recalculo de perfil ML). Si RabbitMQ no
# está disponible, la API sigue funcionando normal para activos.
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Opcional: si no se define, se usa http://localhost:8006
# URL de vault-ai-service para moderar posts/comentarios/reseñas ANTES de
# guardarlos. Si este servicio no responde, la publicación se rechaza
# (política: bloquear si no se puede verificar el contenido).
NLP_SERVICE_URL=http://localhost:8006
